ANTHROPIC_API_KEY=your_anthropic_api_key_here

YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
# Get free key: console.cloud.google.com > New Project > YouTube Data API v3 > Credentials

# Webshare rotating residential proxy (get credentials at dashboard.webshare.io)
WEBSHARE_PROXY_USERNAME=your_webshare_proxy_username
WEBSHARE_PROXY_PASSWORD=your_webshare_proxy_password

# Channel download limits
MAX_VIDEOS_DEFAULT=20
MIN_VIDEO_DURATION_SECONDS=300

# Model config — one line per task type, change here to upgrade/downgrade
# Haiku: fast, cheap, good for high-volume extraction
# Sonnet: better synthesis and writing quality, ~5-8x cost of Haiku
ANALYZER_MODEL=claude-haiku-4-5-20251001
DIGEST_MODEL=claude-haiku-4-5-20251001
QUERY_MODEL=claude-sonnet-4-6

# Pain point extractor settings
ANALYZER_MAX_FILES=50

# Buffer — LinkedIn post scheduler
# Get access token: buffer.com/developers/apps > your app > OAuth flow
# Org ID and Channel ID: query Buffer GraphQL API after connecting LinkedIn
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here
BUFFER_ORG_ID=your_buffer_org_id_here
BUFFER_LINKEDIN_CHANNEL_ID=your_buffer_linkedin_channel_id_here

# Skool community downloader
# Used by: python -m src.main skool-download --community <slug> --group "name" --limit N
SKOOL_EMAIL=your_skool_login_email
SKOOL_PASSWORD=your_skool_login_password

# Newsletter curator — fetches via the "outlook-composio" MCP connection
# (configured in Claude Code's MCP settings, not here). No env vars needed.
# Used by: python -m src.main curate-newsletters --discover [--days N]

# Kit (ConvertKit) — email funnel. Use a V4 key (Kit dashboard > Settings > Developer).
# V4 auth is a single key sent as a Bearer/X-Kit-Api-Key header (no secret needed).
# Used by: python -m src.main kit-sync  (pulls the Steel cohort into a warm-list)
KIT_API_KEY=your_kit_v4_api_key_here

# WordPress (rskiles.com) — used as a public image/PDF host for Buffer asset URLs.
# Create at: rskiles.com/wp-admin > Users > Profile > Application Passwords.
# Username is your normal WP login username, not your email.
WP_URL=https://rskiles.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password_here
