ANTHROPIC_API_KEY=your_anthropic_api_key_here

YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
# Get free key: console.cloud.google.com > New Project > YouTube Data API v3 > Credentials

# Webshare rotating residential proxy (get credentials at dashboard.webshare.io)
WEBSHARE_PROXY_USERNAME=your_webshare_proxy_username
WEBSHARE_PROXY_PASSWORD=your_webshare_proxy_password

# Channel download limits
MAX_VIDEOS_DEFAULT=20
MIN_VIDEO_DURATION_SECONDS=300

# Model config — one line per task type, change here to upgrade/downgrade
# Haiku: fast, cheap, good for high-volume extraction
# Sonnet: better synthesis and writing quality, ~5-8x cost of Haiku
ANALYZER_MODEL=claude-haiku-4-5-20251001
DIGEST_MODEL=claude-haiku-4-5-20251001
QUERY_MODEL=claude-sonnet-4-6

# Pain point extractor settings
ANALYZER_MAX_FILES=50
